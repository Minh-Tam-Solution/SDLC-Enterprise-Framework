{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdlc-framework.org/spec/evidence/frontmatter/v1",
  "title": "SDLC Specification Frontmatter Schema",
  "description": "YAML frontmatter schema for SDLC specification documents",
  "type": "object",
  "required": [
    "spec_id",
    "title",
    "version",
    "status",
    "tier",
    "pillar",
    "owner",
    "last_updated"
  ],
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^SPEC-[0-9]{4}$",
      "description": "Unique specification identifier (e.g., SPEC-0001)",
      "examples": ["SPEC-0001", "SPEC-0002"]
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 150,
      "description": "Specification title"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "REVIEW", "APPROVED", "ACTIVE", "DEPRECATED"],
      "description": "Specification lifecycle status"
    },
    "tier": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["LITE", "STANDARD", "PROFESSIONAL", "ENTERPRISE"]
      },
      "description": "Applicable tiers"
    },
    "pillar": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(Pillar [0-7]|Section [0-9]+).*$"
      },
      "description": "Related SDLC pillars"
    },
    "owner": {
      "type": "string",
      "description": "Specification owner (role or team)"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last modification date (YYYY-MM-DD)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Searchable tags"
    },
    "related_specs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SPEC-[0-9]{4}$"
      },
      "description": "Related specification IDs"
    }
  }
}
